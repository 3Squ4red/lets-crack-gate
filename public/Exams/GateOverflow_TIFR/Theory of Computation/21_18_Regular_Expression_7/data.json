        {
          "id": 1,
          "question": "<p><a name=\"19047\"></a><div itemprop=\"text\"><p>Let \\( r, s, t \\) be regular expressions. Which of the following identities is correct?</p></div><br><br><b>TIFR CSE 2010 | Part B | Question: 34</b></p>",
          "type": "single",
          "options": [
            "<p>\\( (r + s)^* = r^*s^* \\)</p>",
            "<p>\\( r(s + t) = rs + t \\)</p>",
            "<p>\\( (r + s)^* = r^* + s^* \\)</p>",
            "<p>\\( (rs + r)^* r = r (sr + r)^* \\)</p>",
            "<p>\\( (r^*s)^* = (rs)^* \\)</p>"
          ],
          "correct_answer": "<p>\\( (rs + r)^* r = r (sr + r)^* \\)</p>",
          "marks": 1,
          "negative_marks": 0.33,
          "explanation": "<p><a href=\"https://gateoverflow.in/19047/tifr-cse-2010-part-b-question-34\" target=\"_blank\">https://gateoverflow.in/19047/tifr-cse-2010-part-b-question-34</a></p>"
        },
        {
          "id": 2,
          "question": "<p><a name=\"29861\"></a><div itemprop=\"text\"><p>Let \\( a, b, c \\) be regular expressions. Which of the following identities is correct?</p>\n\n</div><br><br><b>TIFR CSE 2015 | Part B | Question: 7</b></p>",
          "type": "single",
          "options": [
            "<p>\\( (a + b)^{*} = a^{*}b^{*} \\)</p>",
            "<p>\\( a(b + c) = ab + c \\)</p>",
            "<p>\\( (a + b)^{*} = a^{*} + b^{*} \\)</p>",
            "<p>\\( (ab + a)^{*}a = a(ba + a)^{*} \\)</p>",
            "<p>None of the above.</p>"
          ],
          "correct_answer": "<p>\\( (ab + a)^{*}a = a(ba + a)^{*} \\)</p>",
          "marks": 1,
          "negative_marks": 0.33,
          "explanation": "<p><a href=\"https://gateoverflow.in/29861/tifr-cse-2015-part-b-question-7\" target=\"_blank\">https://gateoverflow.in/29861/tifr-cse-2015-part-b-question-7</a></p>"
        },
        {
          "id": 4,
